# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key       # server-only, never expose

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
GOOGLE_AI_API_KEY=your_gemini_key

# Keyword Data
SERPER_API_KEY=your_serper_dev_key       # serper.dev — cheapest SERP data

# Cron Security
CRON_SECRET=random_secret_string           # protects /api/cron/daily-scan endpoint

# Email (Resend)
RESEND_API_KEY=your_resend_api_key           # resend.com — email alerts

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
